---
import { ClientRouter } from 'astro:transitions';
import Stars from '../components/Stars.astro';
import FloatingBackground from '../components/FloatingBackground.astro';
import BackgroundMusic from '../components/BackgroundMusic.astro';
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <Stars />
    <FloatingBackground />
    <BackgroundMusic src="/audio/cancion.mp3" />
    <slot />
  </body>
</html>