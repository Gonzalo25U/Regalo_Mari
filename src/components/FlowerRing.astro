---
interface Props {
  count?: number;
  width?: number;
  height?: number;
}
const { count = 12, width = 460, height = 460 } = Astro.props;

const flowers = Array.from({ length: count }, (_, i) => {
  const t = (i / count) * Math.PI * 2;

  const rawX = 16 * Math.pow(Math.sin(t), 3);
  const rawY =
    15 * Math.cos(t) -
    5 * Math.cos(2 * t) -
    2 * Math.cos(3 * t) -
    Math.cos(4 * t);

  const offsetX = (rawX / 17) * (width / 2);
  const offsetY = -(rawY / 17) * (height / 2);

  const tangentX = 48 * Math.pow(Math.sin(t), 2) * Math.cos(t) * (width / 17);
  const tangentY =
    -(-13 * Math.sin(t) + 10 * Math.sin(2 * t) + 6 * Math.sin(3 * t) + 4 * Math.sin(4 * t)) *
    (height / 17);

  return {
    offsetX,
    offsetY,
    rotation: (Math.atan2(-tangentY, tangentX) * 180) / Math.PI + 90,
    hue: ['rose', 'gold', 'lavender'][i % 3],
    scale: 0.8 + Math.random() * 0.4,
  };
});
---
<div
  class="flower-ring-wrap"
  style={`--ring-h:${height}px; --ring-w:${width}px;`}
>
  <div class="flower-ring" aria-hidden="true">
    {flowers.map((f) => (
      <div
        class={`flower flower-${f.hue}`}
        style={`left:50%; top:50%; transform: translate(calc(-50% + ${f.offsetX}px), calc(-50% + ${f.offsetY}px)) rotate(${f.rotation}deg) scale(${f.scale});`}
      >
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="flower-center"></span>
      </div>
    ))}
  </div>
  <div class="flower-ring-content">
    <slot />
  </div>
</div>

<style>
  .flower-ring-wrap {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
    /* altura base = el anillo completo */
    min-height: var(--ring-h);
  }

  .flower-ring {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .flower-ring-content {
    position: relative;
    z-index: 1;
    max-width: 80%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .flower {
    position: absolute;
    width: 26px;
    height: 26px;
  }

  .petal {
    position: absolute;
    width: 12px;
    height: 16px;
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    left: 7px;
    top: 0;
    transform-origin: bottom center;
  }
  .petal:nth-child(1) { transform: rotate(0deg); }
  .petal:nth-child(2) { transform: rotate(72deg); }
  .petal:nth-child(3) { transform: rotate(144deg); }
  .petal:nth-child(4) { transform: rotate(216deg); }
  .petal:nth-child(5) { transform: rotate(288deg); }

  .flower-center {
    position: absolute;
    left: 9px; top: 9px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--gold-light);
  }

  .flower-rose .petal     { background: var(--rose);     opacity: .85; }
  .flower-gold .petal     { background: var(--gold);     opacity: .85; }
  .flower-lavender .petal { background: var(--lavender); opacity: .85; }

  /* ── Mobile: scale the ring canvas, compensate the container height ── */
  @media (max-width: 700px) {
    .flower-ring {
      transform: scale(0.55);
      transform-origin: center top;
    }
    .flower-ring-wrap {
      /* altura real que ocupa el anillo escalado */
      min-height: calc(var(--ring-h) * 0.55) !important;
    }
  }

  @media (max-width: 420px) {
    .flower-ring {
      transform: scale(0.42);
      transform-origin: center top;
    }
    .flower-ring-wrap {
      min-height: calc(var(--ring-h) * 0.42) !important;
    }
  }
</style>