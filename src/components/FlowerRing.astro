---
interface Props {
  count?: number;
  width?: number;
  height?: number;
}
// count ahora es flores por fila (arriba y abajo)
const { count = 12 } = Astro.props;

const hues = ['rose', 'gold', 'lavender'] as const;

const topRow = Array.from({ length: count }, (_, i) => ({
  hue: hues[i % 3],
  sc: (0.75 + Math.random() * 0.5).toFixed(3),
  dy: (Math.random() * 10 - 5).toFixed(1),   // pequeña variación vertical
}));

const bottomRow = Array.from({ length: count }, (_, i) => ({
  hue: hues[(i + 1) % 3],
  sc: (0.75 + Math.random() * 0.5).toFixed(3),
  dy: (Math.random() * 10 - 5).toFixed(1),
}));
---
<div class="frw">
  <!-- fila superior -->
  <div class="flower-row flower-row--top" aria-hidden="true">
    {topRow.map((f) => (
      <div class={`flower flower-${f.hue}`} style={`--sc:${f.sc}; --dy:${f.dy}px;`}>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="flower-center"></span>
      </div>
    ))}
  </div>

  <!-- contenido -->
  <div class="frw-content">
    <slot />
  </div>

  <!-- fila inferior -->
  <div class="flower-row flower-row--bottom" aria-hidden="true">
    {bottomRow.map((f) => (
      <div class={`flower flower-${f.hue}`} style={`--sc:${f.sc}; --dy:${f.dy}px;`}>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="flower-center"></span>
      </div>
    ))}
  </div>
</div>

<style>
  .frw {
    overflow: hidden;
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── filas de flores ── */
  .flower-row {
    width: 100%;
    display: flex;
    justify-content: space-around;
    align-items: center;
    flex-wrap: nowrap;
    pointer-events: none;
    padding: 0 8px;
    box-sizing: border-box;
  }

  /* contenido entre las dos filas */
  .frw-content {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12px 16px;
    box-sizing: border-box;
  }

  /* ── flor individual ── */
  .flower {
    position: relative;
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    transform: translateY(var(--dy)) scale(var(--sc));
  }

  .petal {
    position: absolute;
    width: 10px;
    height: 14px;
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    left: 8px;
    top: 0;
    transform-origin: bottom center;
  }
  .petal:nth-child(1) { transform: rotate(0deg); }
  .petal:nth-child(2) { transform: rotate(72deg); }
  .petal:nth-child(3) { transform: rotate(144deg); }
  .petal:nth-child(4) { transform: rotate(216deg); }
  .petal:nth-child(5) { transform: rotate(288deg); }

  .flower-center {
    position: absolute;
    left: 9px; top: 9px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--gold-light);
  }

  .flower-rose .petal     { background: var(--rose);     opacity: .9; }
  .flower-gold .petal     { background: var(--gold);     opacity: .9; }
  .flower-lavender .petal { background: var(--lavender); opacity: .9; }

  /* En móvil reducir un poco el tamaño de las flores */
  @media (max-width: 480px) {
    .flower {
      width: 20px;
      height: 20px;
    }
    .petal {
      width: 8px;
      height: 11px;
      left: 6px;
    }
    .flower-center {
      width: 6px; height: 6px;
      left: 7px; top: 7px;
    }
  }
</style>