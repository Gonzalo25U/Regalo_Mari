---
interface Props {
  count?: number;
  width?: number;
  height?: number;
}
const { count = 12, width = 1, height = 1 } = Astro.props;

const flowers = Array.from({ length: count }, (_, i) => {
  const t = (i / count) * Math.PI * 2;
  return {
    t,
    hue: ['rose', 'gold', 'lavender'][i % 3],
    sc: (0.8 + Math.random() * 0.4).toFixed(3),
  };
});
---
<div
  class="flower-ring-wrap"
  data-aspect-w={width}
  data-aspect-h={height}
>
  <div class="flower-ring" aria-hidden="true">
    {flowers.map((f) => (
      <div
        class={`flower flower-${f.hue}`}
        data-t={f.t.toFixed(6)}
        data-sc={f.sc}
      >
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="flower-center"></span>
      </div>
    ))}
  </div>
  <div class="flower-ring-content">
    <slot />
  </div>
</div>

<style>
  .flower-ring-wrap {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }

  .flower-ring {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .flower {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 26px;
    height: 26px;
    transform: translate(-50%, -50%);
    will-change: transform;
    z-index: 0;
  }

  .flower-ring-content {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px 16px;
    box-sizing: border-box;
  }

  .petal {
    position: absolute;
    width: 12px;
    height: 16px;
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    left: 7px;
    top: 0;
    transform-origin: bottom center;
  }
  .petal:nth-child(1) { transform: rotate(0deg); }
  .petal:nth-child(2) { transform: rotate(72deg); }
  .petal:nth-child(3) { transform: rotate(144deg); }
  .petal:nth-child(4) { transform: rotate(216deg); }
  .petal:nth-child(5) { transform: rotate(288deg); }

  .flower-center {
    position: absolute;
    left: 9px; top: 9px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--gold-light);
  }

  .flower-rose .petal     { background: var(--rose);     opacity: .85; }
  .flower-gold .petal     { background: var(--gold);     opacity: .85; }
  .flower-lavender .petal { background: var(--lavender); opacity: .85; }
</style>

<script>
  function positionFlowers(wrap: HTMLElement) {
    const aspectW = parseFloat(wrap.dataset.aspectW || '1');
    const aspectH = parseFloat(wrap.dataset.aspectH || '1');
    const proportion = aspectH / aspectW;

    const content = wrap.querySelector<HTMLElement>('.flower-ring-content');
    if (!content) return;

    const contentW = content.offsetWidth;
    const contentH = content.offsetHeight;
    const wrapW    = wrap.clientWidth;

    // Radio mínimo: suficiente para no pisar el contenido (diagonal del contenido / 2 + margen)
    const minRadius = Math.sqrt((contentW / 2) ** 2 + (contentH / 2) ** 2) + 48;

    // En pantallas pequeñas el contenido ocupa casi todo el ancho,
    // así que el radio mínimo ya es grande — lo respetamos siempre.
    // En desktop el wrapper es amplio y el radio natural (55% del ancho) ya supera el mínimo.
    const naturalRadius = wrapW * 0.55;
    const radiusX = Math.max(minRadius, naturalRadius);
    const radiusY = radiusX * proportion;

    wrap.querySelectorAll<HTMLElement>('.flower').forEach((flower) => {
      const t  = parseFloat(flower.dataset.t  || '0');
      const sc = parseFloat(flower.dataset.sc || '1');

      const rawX = 16 * Math.pow(Math.sin(t), 3);
      const rawY =
        15 * Math.cos(t) -
        5  * Math.cos(2 * t) -
        2  * Math.cos(3 * t) -
             Math.cos(4 * t);

      const ox = (rawX / 17) * radiusX;
      const oy = -(rawY / 17) * radiusY;

      const tx = 48 * Math.pow(Math.sin(t), 2) * Math.cos(t) * radiusX;
      const ty = -(
        -13 * Math.sin(t) +
         10 * Math.sin(2 * t) +
          6 * Math.sin(3 * t) +
          4 * Math.sin(4 * t)
      ) * radiusY;
      const rotation = (Math.atan2(-ty, tx) * 180) / Math.PI + 90;

      flower.style.transform =
        `translate(calc(-50% + ${ox}px), calc(-50% + ${oy}px)) rotate(${rotation}deg) scale(${sc})`;
    });

    // El wrapper necesita albergar tanto el contenido como las flores
    wrap.style.minHeight = `${Math.max(contentH + 40, radiusY * 2 + 40)}px`;
  }

  function initAll() {
    document.querySelectorAll<HTMLElement>('.flower-ring-wrap').forEach((wrap) => {
      requestAnimationFrame(() => {
        positionFlowers(wrap);
        const ro = new ResizeObserver(() => positionFlowers(wrap));
        ro.observe(wrap);
        document.addEventListener('astro:before-swap', () => ro.disconnect(), { once: true });
      });
    });
  }

  document.addEventListener('astro:page-load', initAll);
</script>