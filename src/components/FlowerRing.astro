---
interface Props {
  count?: number;
  width?: number;  // ancho del corazón en píxeles
  height?: number; // alto del corazón en píxeles
}
const { count = 12, width = 460, height = 460 } = Astro.props;

// Curva paramétrica del corazón:
// x(t) = 16 sin³(t)
// y(t) = 13 cos(t) − 5 cos(2t) − 2 cos(3t) − cos(4t)
const flowers = Array.from({ length: count }, (_, i) => {
  const t = (i / count) * Math.PI * 2;

  const rawX = 16 * Math.pow(Math.sin(t), 3);
  const rawY =
    15 * Math.cos(t) -
    5 * Math.cos(2 * t) -
    2 * Math.cos(3 * t) -
    Math.cos(4 * t);

  // cada eje se escala con su propio tamaño: ya no están atados entre sí
  const offsetX = (rawX / 17) * (width / 2);
  const offsetY = -(rawY / 17) * (height / 2);

  // para la rotación (que la flor "mire" tangente a la curva), también hay que
  // compensar la deformación de escalar X e Y distinto, si no, la rotación queda mal
  const tangentX = 48 * Math.pow(Math.sin(t), 2) * Math.cos(t) * (width / 17);
  const tangentY =
    -(-13 * Math.sin(t) + 10 * Math.sin(2 * t) + 6 * Math.sin(3 * t) + 4 * Math.sin(4 * t)) *
    (height / 17);

  return {
    offsetX,
    offsetY,
    rotation: (Math.atan2(-tangentY, tangentX) * 180) / Math.PI + 90,
    hue: ['rose', 'gold', 'lavender'][i % 3],
    scale: 0.8 + Math.random() * 0.4,
  };
});
---
<div class="flower-ring-wrap" style={`min-height:${height}px;`}>
  <div class="flower-ring" aria-hidden="true">
    {flowers.map((f) => (
      <div
        class={`flower flower-${f.hue}`}
        style={`left:50%; top:50%; transform: translate(calc(-50% + ${f.offsetX}px), calc(-50% + ${f.offsetY}px)) rotate(${f.rotation}deg) scale(${f.scale});`}
      >
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="petal"></span>
        <span class="flower-center"></span>
      </div>
    ))}
  </div>
  <div class="flower-ring-content">
    <slot />
  </div>
</div>

<style>
  .flower-ring-wrap {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .flower-ring {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .flower-ring-content {
    position: relative;
    z-index: 1;
    max-width: 80%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .flower {
    position: absolute;
    width: 26px;
    height: 26px;
  }
  .petal {
    position: absolute;
    width: 12px;
    height: 16px;
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    left: 7px;
    top: 0;
    transform-origin: bottom center;
  }
  .petal:nth-child(1) { transform: rotate(0deg); }
  .petal:nth-child(2) { transform: rotate(72deg); }
  .petal:nth-child(3) { transform: rotate(144deg); }
  .petal:nth-child(4) { transform: rotate(216deg); }
  .petal:nth-child(5) { transform: rotate(288deg); }

  .flower-center {
    position: absolute;
    left: 9px; top: 9px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--gold-light);
  }

  .flower-rose .petal { background: var(--rose); opacity: .85; }
  .flower-gold .petal { background: var(--gold); opacity: .85; }
  .flower-lavender .petal { background: var(--lavender); opacity: .85; }

  @media (max-width: 600px) {
    .flower-ring {
      transform: scale(0.62);
      transform-origin: center;
    }
    .flower-ring-wrap {
      min-height: 0 !important; /* dejamos que el contenido defina el alto en mobile */
    }
  }
    .flower-ring-wrap {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }
</style>