---
interface Props {
  src: string;
}
const { src } = Astro.props;
---
<div id="musicShell" transition:persist>
  <audio id="bgMusic" src={src} loop preload="auto"></audio>
  <div id="musicPlayer" class="music-player" aria-live="polite">
    <button id="playPauseToggle" class="music-control" aria-label="Pausar música">❚❚</button>
    <div class="music-info">
      <span id="musicTitle" class="music-title">Música</span>
      <span id="musicTime" class="music-time">0:00 / 0:00</span>
    </div>
  </div>
  <button id="muteToggle" class="mute-toggle" aria-label="Silenciar música">♪</button>
</div>

<style>
  .music-player {
    position: fixed;
    right: 18px;
    bottom: 70px;
    z-index: 50;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 999px;
    border: 1px solid rgba(231,207,140,.35);
    background: rgba(42,16,32,.78);
    color: var(--gold-light);
    backdrop-filter: blur(6px);
    box-shadow: 0 8px 24px rgba(0,0,0,.24);
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity .25s ease, transform .25s ease;
  }
  .music-player.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .music-control {
    border: 0;
    background: rgba(255,255,255,.12);
    color: var(--gold-light);
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    cursor: pointer;
    font-size: 0.95rem;
  }
  .music-info {
    display: flex;
    flex-direction: column;
    min-width: 130px;
  }
  .music-title {
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .music-time {
    font-size: 0.7rem;
    opacity: 0.8;
  }
  .mute-toggle {
    position: fixed;
    bottom: 18px; right: 18px;
    z-index: 50;
    width: 42px; height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(231,207,140,.4);
    background: rgba(42,16,32,.7);
    color: var(--gold-light);
    font-size: 1.1rem;
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: opacity .3s ease, transform .2s ease;
    opacity: 0;
    pointer-events: none;
  }
  .mute-toggle.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  .mute-toggle:hover { transform: scale(1.08); }
  .mute-toggle.is-muted { color: var(--rose); }
</style>

<script>
  function setup() {
    const audio = document.getElementById('bgMusic') as HTMLAudioElement | null;
    const toggle = document.getElementById('muteToggle') as HTMLButtonElement | null;
    const player = document.getElementById('musicPlayer') as HTMLDivElement | null;
    const playPauseBtn = document.getElementById('playPauseToggle') as HTMLButtonElement | null;
    const titleEl = document.getElementById('musicTitle') as HTMLSpanElement | null;
    const timeEl = document.getElementById('musicTime') as HTMLSpanElement | null;
    if (!audio || !toggle || !player || !playPauseBtn || !titleEl || !timeEl) return;

    const audioEl = audio;
    const toggleEl = toggle;
    const playerEl = player;
    const playPauseBtnEl = playPauseBtn;
    const titleTextEl = titleEl;
    const timeTextEl = timeEl;

    const globalState = window as Window & {
      __birthdayMusicStart?: () => Promise<void>;
      __birthdayMusicShared?: {
        hasStarted: boolean;
      };
    };

    if (!globalState.__birthdayMusicShared) {
      globalState.__birthdayMusicShared = { hasStarted: false };
    }
    const musicShared = globalState.__birthdayMusicShared;

    function getSongTitle(src: string) {
      const fileName = src.split('/').pop() || 'Música';
      return decodeURIComponent(fileName.replace(/\.mp3$/i, '').replace(/%20/g, ' '));
    }

    function formatTime(seconds: number) {
      const safe = Number.isFinite(seconds) ? Math.max(0, Math.floor(seconds)) : 0;
      const mins = Math.floor(safe / 60);
      const secs = safe % 60;
      return `${mins}:${secs.toString().padStart(2, '0')}`;
    }

    function updateUI() {
      const duration = Number.isFinite(audioEl.duration) ? audioEl.duration : 0;
      timeTextEl.textContent = `${formatTime(audioEl.currentTime)} / ${formatTime(duration)}`;
      playPauseBtnEl.textContent = audioEl.paused ? '▶' : '❚❚';
      playPauseBtnEl.setAttribute('aria-label', audioEl.paused ? 'Reproducir música' : 'Pausar música');
      toggleEl.classList.toggle('is-muted', audioEl.muted);
      playerEl.classList.add('is-active');
      toggleEl.classList.add('is-active');
    }

    async function startMusic() {
      if (!musicShared.hasStarted) {
        audioEl.currentTime = 0;
      }

      try {
        await audioEl.play();
        musicShared.hasStarted = true;
        updateUI();
      } catch {
        updateUI();
      }
    }

    globalState.__birthdayMusicStart = startMusic;

    audioEl.volume = 0.4;
    audioEl.loop = true;
    titleTextEl.textContent = getSongTitle(audioEl.currentSrc || audioEl.src);
    updateUI();

    audioEl.addEventListener('play', updateUI);
    audioEl.addEventListener('pause', updateUI);
    audioEl.addEventListener('timeupdate', updateUI);

    playPauseBtnEl.addEventListener('click', (e) => {
      e.stopPropagation();
      if (audioEl.paused) {
        void startMusic();
      } else {
        audioEl.pause();
      }
    });

    toggleEl.addEventListener('click', (e) => {
      e.stopPropagation();
      if (audioEl.muted) {
        audioEl.muted = false;
        toggleEl.classList.remove('is-muted');
      } else {
        audioEl.muted = true;
        toggleEl.classList.add('is-muted');
      }
    });
  }

  setup();
</script>