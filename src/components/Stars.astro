---
// Las posiciones se generan en build time, en el servidor: no se necesita JS en el navegador.
const STAR_COUNT = 60;
const stars = Array.from({ length: STAR_COUNT }, () => ({
  left: Math.random() * 100,
  top: Math.random() * 100,
  delay: Math.random() * 4,
}));
---
<div class="stars" aria-hidden="true">
  {stars.map((s) => (
    <span style={`left:${s.left}%; top:${s.top}%; animation-delay:${s.delay}s;`}></span>
  ))}
</div>

<style>
  .stars{ position:fixed; inset:0; z-index:0; pointer-events:none; }
  .stars span{
    position:absolute; width:2px; height:2px; background:var(--gold-light);
    border-radius:50%; opacity:.5; animation:twinkle 4s ease-in-out infinite;
  }
  @keyframes twinkle{ 0%,100%{opacity:.15;} 50%{opacity:.8;} }
</style>