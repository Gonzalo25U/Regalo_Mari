---
import type { Photo } from '../data/photos';

interface Props {
  photos: Photo[];
}
const { photos } = Astro.props;
---
<div class="photo-grid">
  {photos.map((p, i) => (
    <div class="photo-frame" style={`--d:${(i * 0.1).toFixed(2)}s; --r:${(Math.random() * 4 - 2).toFixed(2)}deg;`}>
      {p.src
        ? <img src={p.src} alt={p.alt} class="lightbox-trigger" data-full-src={p.src} data-full-alt={p.alt} />
        : <div class="photo-placeholder">🤍</div>}
    </div>
  ))}
</div>

<style>
  .photo-grid {
    display: grid;
    grid-template-rows: repeat(2, 1fr);
    grid-auto-flow: column;
    grid-auto-columns: minmax(110px, 150px);
    gap: 14px;
    margin-top: 28px;
    width: 100%;
    justify-content: center;
  }
  .photo-frame {
    aspect-ratio: 1;
    background: var(--paper);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 14px 28px rgba(0,0,0,.35);
    transform: rotate(var(--r, 0deg));
    opacity: 0;
    animation: frameIn .55s ease forwards;
    animation-delay: var(--d, 0s);
    display: flex; align-items: center; justify-content: center;
  }
  @keyframes frameIn {
    from { opacity: 0; transform: translateY(14px) rotate(var(--r, 0deg)); }
    to { opacity: 1; transform: translateY(0) rotate(var(--r, 0deg)); }
  }
  .lightbox-trigger {
    width: 100%; height: 100%; object-fit: cover;
    cursor: zoom-in;
    transition: transform .25s ease;
  }
  .lightbox-trigger:hover { transform: scale(1.04); }
  .photo-placeholder { font-size: 2rem; opacity: .4; }
  
  @media (max-width: 600px) {
  .photo-grid {
    grid-auto-columns: minmax(90px, 120px);
    overflow-x: auto;
    justify-content: start;
    padding-bottom: 6px;
  }
}
</style>